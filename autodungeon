local function saveReturnData()
    local data = {
        world = savedReturnWorld,
        cframe = savedReturnCFrame and {savedReturnCFrame:GetComponents()} or nil,
        wasInDungeon = wasInDungeon,
        wasInGate = wasInGate
    }
    pcall(function()
        writefile("AnimeAstral_ReturnData.json", HttpService:JSONEncode(data))
    end)
end

local function loadReturnData()
    pcall(function()
        if isfile and isfile("AnimeAstral_ReturnData.json") then
            local data = HttpService:JSONDecode(readfile("AnimeAstral_ReturnData.json"))
            savedReturnWorld = data.world
            wasInDungeon = data.wasInDungeon
            wasInGate = data.wasInGate
            if data.cframe then
                savedReturnCFrame = CFrame.new(unpack(data.cframe))
            end
            warn(string.format("[AutoReturn] Loaded saved return data. World: %s", tostring(savedReturnWorld)))
        end
    end)
end

