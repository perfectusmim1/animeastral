local function getGateRankIfAllowed()
    local hud = LocalPlayer.PlayerGui:FindFirstChild("HUD")
    local notifyGate = hud and hud:FindFirstChild("Main")
        and hud.Main:FindFirstChild("GamemodeNotify")
        and hud.Main.GamemodeNotify:FindFirstChild("Notify_Raid_World5")
    if notifyGate and notifyGate.Visible then
        local desc = notifyGate:FindFirstChild("Description")
        if desc and desc:IsA("TextLabel") then
            local text = desc.Text
            local rank = text:match("Rank ([%w]+) Gate")
            if rank then
                local selectedRanks = selectedMultiValues(Options.GateRanks.Value)
                for _, r in ipairs(selectedRanks) do
                    if r == rank then
                        return true, rank
                    end
                end
            end
        end
    end
    return false, nil
end

