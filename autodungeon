local function onPriorityChanged(changedDrop, newVal)
    if updatingPriority then return end
    updatingPriority = true
    for _, entry in ipairs(allPriorityDrops) do
        if entry.drop ~= changedDrop and Options[entry.key].Value == newVal then
            local usedValues = {}
            for _, e in ipairs(allPriorityDrops) do
                usedValues[Options[e.key].Value] = true
            end
            for _, v in ipairs(PRIORITY_VALUES) do
                if not usedValues[v] then
                    entry.drop:SetValue(v)
                    break
                end
            end
            break
        end
    end
    updatingPriority = false
end

