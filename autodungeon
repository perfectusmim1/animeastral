local function refreshEnemies()
    local enemyLabels = {}
    local folder = activeEnemiesFolder()
    if not folder then
        return
    end

    local found = {}
    for _, enemy in ipairs(folder:GetChildren()) do
        local cf = getObjectCFrame(enemy)
        if cf then
            local etype = enemy:GetAttribute("EnemyType") or "Unknown"
            local label = enemy.Name .. " - " .. tostring(etype)
            if not found[label] then
                found[label] = true
                table.insert(enemyLabels, label)
            end
        end
    end

    table.sort(enemyLabels)
    if #enemyLabels == 0 then enemyLabels = { "--" } end
    setDropdownValues(EnemyDropdown, enemyLabels)

    if EnemyDropdown then
        local currentVal = EnemyDropdown.Value
        local newVal = {}
        local labelSet = {}
        for _, l in ipairs(enemyLabels) do labelSet[l] = true end
        
        local changed = false
        if type(currentVal) == "table" then
            for k, v in pairs(currentVal) do
                if type(v) == "string" then
                    if labelSet[v] then
                        table.insert(newVal, v)
                    else
                        changed = true
                    end
                elseif type(k) == "string" and v == true then
                    if labelSet[k] then
                        newVal[k] = true
                    else
                        changed = true
                    end
                end
            end
        end
        if changed then
            pcall(function() EnemyDropdown:SetValue(newVal) end)
        end
    end
end

local function selectedEnemyInstances()
    local targets = {}
    local val = (Options.EnemyDropdown and Options.EnemyDropdown.Value) or {}
    local sel = selectedMultiValues(val)

    local folder = activeEnemiesFolder()
    if not folder then return targets end

    local selSet = {}
    for _, label in ipairs(sel) do selSet[label] = true end

    for _, enemy in ipairs(folder:GetChildren()) do
        if isEnemyAlive(enemy) then
            local etype = enemy:GetAttribute("EnemyType") or "Unknown"
            local label = enemy.Name .. " - " .. tostring(etype)
            if #sel == 0 or selSet[label] then
                table.insert(targets, enemy)
            end
        end
    end
    return targets
end

local function getPartRadius(part)
    if not part or not part:IsA("BasePart") then return nil end
    local sizes = {part.Size.X, part.Size.Y, part.Size.Z}
    table.sort(sizes)
    return sizes[3] / 2
end

local function getPlayerRange()
    local ok, radius = pcall(function()
        local range = workspace:FindFirstChild("RangeLv1")
        if not range then return 15 end
        local main = range:FindFirstChild("Main")
        if main then
            local circle = main:FindFirstChild("Circle")
            local r = getPartRadius(circle) or getPartRadius(main)
            if r then return r end
        end
        local r = getPartRadius(range:FindFirstChild("HitBox"))
        if r then return r end
        return 15
    end)
    return (ok and radius) or 15
end

local function robustClickObject(obj)
    if not obj then return false end
    if typeof(fireclick) == "function" then
        if pcall(fireclick, obj) then return true end
    end
    if typeof(firesignal) == "function" then
        local clicked = false
        pcall(function() firesignal(obj.MouseButton1Click); clicked = true end)
        pcall(function() firesignal(obj.Activated); clicked = true end)
        if clicked then return true end
    end
    if typeof(getconnections) == "function" then
        local fired = false
        pcall(function()
            for _, conn in ipairs(getconnections(obj.MouseButton1Click)) do conn:Fire(); fired = true end
            for _, conn in ipairs(getconnections(obj.Activated)) do conn:Fire(); fired = true end
        end)
        if fired then return true end
    end
    local vimSuccess = pcall(function()
        if obj.AbsoluteSize.X > 0 and obj.AbsoluteSize.Y > 0 then
            local inset = GuiService:GetGuiInset()
            local x = obj.AbsolutePosition.X + (obj.AbsoluteSize.X / 2)
            local y = obj.AbsolutePosition.Y + (obj.AbsoluteSize.Y / 2) + inset.Y
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
            task.wait(0.04)
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
        end
    end)
    if vimSuccess then return true end
    if pcall(function() obj:Activate() end) then return true end
    return false
end

local function MovementGoTo(targetCFrame)
    local root = getRootPart()
    if not root then return false end
    pcall(function()
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        root.CFrame = targetCFrame
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end)
    return false
end

local function executeAutoReturn()
    pcall(disableHover)
    if not savedReturnWorld or not savedReturnCFrame then 
        return 
    end
    
    -- Wait for any initial loading screen from leaving the Dungeon/Gate to finish
    pcall(function()
        local tl = LocalPlayer.PlayerGui:FindFirstChild("Windows")
        if tl then 
            local teleportLoading = tl:FindFirstChild("TeleportLoading")
            if teleportLoading and teleportLoading.Visible then
                waitForLoadingScreen(teleportLoading, setStatus)
                task.wait(0.5)
            end
        end
    end)

    local currentVis = LocalPlayer:GetAttribute("VisibilityContext")
    local targetVis = "World:" .. tostring(savedReturnWorld)
    
    if currentVis == targetVis then
        MovementGoTo(savedReturnCFrame)
    else
        local worldsFolder = workspace:FindFirstChild("Worlds")
        if worldsFolder then
            local targetWorldFolder = worldsFolder:FindFirstChild(tostring(savedReturnWorld))
            if targetWorldFolder then
                local teleporter = targetWorldFolder:FindFirstChild("Teleporter")
                if tostring(savedReturnWorld) == "0" then
                    teleporter = targetWorldFolder:FindFirstChild("Void")
                end
                
                if teleporter then
                    local root = getRootPart()
                    if root then
                        if typeof(firetouchinterest) == "function" then
                            pcall(function()
                                firetouchinterest(root, teleporter, 0)
                                task.wait(0.1)
                                firetouchinterest(root, teleporter, 1)
                            end)
                        else
                            MovementGoTo(teleporter.CFrame)
                        end
                        
                        local teleportLoading
                        pcall(function()
                            local tl = LocalPlayer.PlayerGui:FindFirstChild("Windows")
                            if tl then teleportLoading = tl:FindFirstChild("TeleportLoading") end
                        end)
                        
                        if teleportLoading then
                            local t = tick()
                            repeat task.wait(0.1) until teleportLoading.Visible or (tick() - t > 5)
                            if teleportLoading.Visible then
                                waitForLoadingScreen(teleportLoading, setStatus)
                                task.wait(0.5)
                            end
                        else
                            task.wait(4)
                        end
                        
                        local newVis = LocalPlayer:GetAttribute("VisibilityContext")
                        if newVis == targetVis then
                            MovementGoTo(savedReturnCFrame)
                        else
                        end
                    end
                else
                end
            else
            end
        else
        end
    end
end

local function waitForLoadingScreen(teleportLoading, statusFunc, timeoutSeconds)
    if not teleportLoading or not teleportLoading.Visible then return end
    statusFunc = statusFunc or setStatus
    timeoutSeconds = timeoutSeconds or 30
    
    local loadingStartTime = tick()
    
    repeat
        task.wait(0.05)
        
        -- Time trial loading screen bug fix:
        -- If the loading text says "Leaving time trial..." and it's been stuck for over 10 seconds,
        -- hide the loading screen and press the Leave button to recover
        if tick() - loadingStartTime > 10 then
            local isTrialLeaving = false
            pcall(function()
                local loadingText = teleportLoading:FindFirstChild("Main")
                    and teleportLoading.Main:FindFirstChild("Loading")
                if loadingText and loadingText:IsA("TextLabel") then
                    if string.find(string.lower(loadingText.Text), "leaving time trial") then
                        isTrialLeaving = true
                    end
                end
            end)
            
            if isTrialLeaving then
                statusFunc("Loading screen stuck (Leaving time trial). Recovering...")
                pcall(function()
                    teleportLoading.Visible = false
                end)
                task.wait(0.5)
                pcall(function()
                    local leaveBtn = LocalPlayer.PlayerGui:FindFirstChild("TrialGui")
                        and LocalPlayer.PlayerGui.TrialGui:FindFirstChild("Main")
                        and LocalPlayer.PlayerGui.TrialGui.Main:FindFirstChild("Leave")
                    if leaveBtn then
                        robustClickObject(leaveBtn)
                    end
                end)
                task.wait(1)
                return
            end
        end
    until not teleportLoading.Visible or (tick() - loadingStartTime > timeoutSeconds)
end

local FarmHeightValue = 6

local function getFarmHeightForType(typeStr)
    if typeStr ~= "Farm" then
        return 6
    end
    local val = tonumber(Options.FarmHeight and Options.FarmHeight.Value)
    if val then return val end
    return FarmHeightValue or 6
end

local function optimalFarmPosition(enemies, typeStr)
    local positions3D = {}
    for _, e in ipairs(enemies) do
        local cf = getObjectCFrame(e)
        if cf then table.insert(positions3D, cf.Position) end
    end
    if #positions3D == 0 then return nil, 0 end
    local h = getFarmHeightForType(typeStr)
    if #positions3D == 1 then
        return CFrame.new(positions3D[1] + Vector3.new(0, h, 0)), 1
    end

    local range = getPlayerRange()

    local centroid = Vector3.zero
    for _, p in ipairs(positions3D) do centroid += p end
    centroid /= #positions3D

    local allFit = true
    for _, p in ipairs(positions3D) do
        local dist = (Vector2.new(p.X, p.Z) - Vector2.new(centroid.X, centroid.Z)).Magnitude
        if dist > range * 0.95 then
            allFit = false
            break
        end
    end
    if allFit then
        return CFrame.new(centroid + Vector3.new(0, h, 0)), #positions3D
    end

    local candidates = {}
    for _, p in ipairs(positions3D) do table.insert(candidates, p) end
    for i = 1, #positions3D do
        for j = i + 1, #positions3D do
            table.insert(candidates, (positions3D[i] + positions3D[j]) / 2)
        end
    end
    table.insert(candidates, centroid)

    local bestPos = candidates[1]
    local bestCount = 0

    for _, candidate in ipairs(candidates) do
        local count = 0
        for _, p in ipairs(positions3D) do
            local dist = (Vector2.new(p.X, p.Z) - Vector2.new(candidate.X, candidate.Z)).Magnitude
            if dist <= range * 0.95 then
                count = count + 1
            end
        end
        if count > bestCount then
            bestCount = count
            bestPos = candidate
        elseif count == bestCount then
            if (candidate - centroid).Magnitude < (bestPos - centroid).Magnitude then
                bestPos = candidate
            end
        end
    end

    local clusterCenter = Vector3.zero
    local clusterCount = 0
    for _, p in ipairs(positions3D) do
        local dist = (Vector2.new(p.X, p.Z) - Vector2.new(bestPos.X, bestPos.Z)).Magnitude
        if dist <= range * 0.95 then
            clusterCenter += p
            clusterCount = clusterCount + 1
        end
    end

    if clusterCount > 0 then
        clusterCenter /= clusterCount
        return CFrame.new(clusterCenter + Vector3.new(0, h, 0)), clusterCount
    else
        return CFrame.new(bestPos + Vector3.new(0, h, 0)), 1
    end
end

