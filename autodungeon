    {drop = DungeonTimesDrop, key = "DungeonTimes"},
    {drop = TrialEasyTimesDrop, key = "TrialEasyTimes"},
    {drop = TrialMediumTimesDrop, key = "TrialMediumTimes"},
}

local updatingTiming = false
local function onTimingChanged(changedDrop, newVal)
    if updatingTiming then return end
    updatingTiming = true
    
    local otherSelected = {}
    for _, dropInfo in ipairs(allTimingDrops) do
        if dropInfo.drop ~= changedDrop then
            local val = (Options[dropInfo.key] and Options[dropInfo.key].Value) or {}
            local sel = selectedMultiValues(val)
            for _, v in ipairs(sel) do
                otherSelected[v] = true
            end
        end
    end
    
    local newValList = selectedMultiValues(newVal)
    local filteredDict = {}
    local conflict = false
    
    for _, v in ipairs(newValList) do
        if otherSelected[v] then
            conflict = true
        else
            filteredDict[v] = true
        end
    end
    
    if conflict then
        Fluent:Notify({
            Title = "Timing Conflict",
            Content = "You selected a time that is already used by another gamemode. The conflicting time has been removed.",
            Duration = 5
        })
        changedDrop:SetValue(filteredDict)
    end
    
    updatingTiming = false
end

