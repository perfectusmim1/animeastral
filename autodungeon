local function farmEnemies(targets, typeStr, zoneStr, checkEnabledFunc, folder)
    local originalCheck = checkEnabledFunc
    checkEnabledFunc = function()
        if isMultiplayerPaused() then return false end
        return originalCheck()
    end
    local statusFunc = typeStr == "Gate" and setGateStatus or setStatus
    
    local useOptimal = true
    if typeStr == "Farm" then
        useOptimal = (Options.PerfectPosition and Options.PerfectPosition.Value ~= nil) and Options.PerfectPosition.Value or PerfectPositionEnabled
    end
    
    local isHoverEnabled = getHoverState(typeStr)

    if #targets > 0 then
        if isHoverEnabled then
            enableHover()
        else
            disableHover()
        end

        local isFastTeleport = (Options.FastTeleportFarm and Options.FastTeleportFarm.Value ~= nil) and Options.FastTeleportFarm.Value or FastTeleportFarmEnabled
        if isFastTeleport then
            if useOptimal then
                local tcf, coveredCount = optimalFarmPosition(targets, typeStr)
                if tcf then
                    local prefix = (zoneStr and zoneStr ~= "") and (zoneStr .. " ") or ""
                    statusFunc(prefix .. "Fast Teleport (Perfect Position)")
                    MovementGoTo(tcf)
                    task.wait(0.01)
                    return
                end
            end

            for _, enemy in ipairs(targets) do
                if not checkEnabledFunc() then break end
                local cf = getObjectCFrame(enemy)
                if cf then
                    local prefix = (zoneStr and zoneStr ~= "") and (zoneStr .. " ") or ""
                    statusFunc(prefix .. "Fast Teleport: " .. enemy.Name)
                    MovementGoTo(cf + Vector3.new(0, getFarmHeightForType(typeStr), 0))
                    task.wait(0.01)
                end
            end
            return
        end

        local initialCount = #targets
        local tcf, coveredCount = nil, 0
        if useOptimal then
            tcf, coveredCount = optimalFarmPosition(targets, typeStr)
        end
        
        if tcf and coveredCount >= 2 then
            local range = getPlayerRange()
            local prefix = (zoneStr and zoneStr ~= "") and (zoneStr .. " ") or ""
            statusFunc(prefix .. "Farming (Perfect Position: " .. coveredCount .. "/" .. #targets .. " enemies)")
            MovementGoTo(tcf)
            
            local startTime = tick()
            while tick() - startTime < 3 and checkEnabledFunc() do
                isHoverEnabled = getHoverState(typeStr)
                if isHoverEnabled then
                    enableHover()
                    MovementGoTo(tcf)
                else
                    disableHover()
                end

                if folder then
                    local currentCount = 0
                    for _, e in ipairs(folder:GetChildren()) do
                        if isEnemyAlive(e) then currentCount = currentCount + 1 end
                    end
                    if currentCount > initialCount then break end
                end

                local anyCoveredAlive = false
                for _, enemy in ipairs(targets) do
                    if isEnemyAlive(enemy) then
                        local ecf = getObjectCFrame(enemy)
                        if ecf then
                            local dist = (Vector2.new(ecf.Position.X, ecf.Position.Z) - Vector2.new(tcf.Position.X, tcf.Position.Z)).Magnitude
                            if dist <= range * 0.95 then
                                anyCoveredAlive = true
                                break
                            end
                        end
                    end
                end
                if not anyCoveredAlive then break end
                task.wait(0.01)
            end
        else
            for _, enemy in ipairs(targets) do
                if not checkEnabledFunc() then break end
                
                if folder then
                    local currentCount = 0
                    for _, e in ipairs(folder:GetChildren()) do
                        if isEnemyAlive(e) then currentCount = currentCount + 1 end
                    end
                    if currentCount > initialCount then break end
                end
                
                while isEnemyAlive(enemy) and checkEnabledFunc() do
                    if not checkEnabledFunc() then break end

                    isHoverEnabled = getHoverState(typeStr)
                    if isHoverEnabled then
                        enableHover()
                    else
                        disableHover()
                    end

                    if folder then
                        local currentCount = 0
                        for _, e in ipairs(folder:GetChildren()) do
                            if isEnemyAlive(e) then currentCount = currentCount + 1 end
                        end
                        if currentCount > initialCount then break end
                    end
                    
                    local cf = getObjectCFrame(enemy)
                    if cf then
                        local prefix = (zoneStr and zoneStr ~= "") and (zoneStr .. " ") or ""
                        statusFunc(prefix .. "Farming: " .. enemy.Name)
                        MovementGoTo(cf + Vector3.new(0, getFarmHeightForType(typeStr), 0))
                    end
                    task.wait(0.01)
                end
            end
        end
    else
        if typeStr == "Farm" then
            disableHover()
        else
            enableHover()
        end
        statusFunc("Waiting for enemies or " .. string.lower(typeStr) .. " finished...")
    end
end

local function waitForWaveSpawn(folder, expectedCount)
    local targets = {}
    if not folder then return targets end

    local function getAlive()
        local t = {}
        for _, e in ipairs(folder:GetChildren()) do
            if isEnemyAlive(e) then table.insert(t, e) end
        end
        return t
    end
    
    targets = getAlive()
    if #targets == 0 or #targets >= expectedCount then return targets end
    
    local stableTime = tick()
    local lastCount = #targets
    
    while tick() - stableTime < 0.6 do
        task.wait(0.01)
        targets = getAlive()
        if #targets >= expectedCount then
            return targets
        elseif #targets > lastCount then
            stableTime = tick()
            lastCount = #targets
        end
    end
    
    return targets
end

